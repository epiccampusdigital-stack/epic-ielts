generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String
  address       String?
  age           Int?
  city          String?
  phone         String?
  expectedBand  Float?
  batch         String?
  role          String    @default("STUDENT")
  attempts      Attempt[]
}

model Paper {
  id              Int           @id @default(autoincrement())
  paperCode       String
  testType        String        // Keep as String to avoid data loss during migration
  title           String
  timeLimitMin    Int           @default(60)
  instructions    String?       @db.Text
  audioUrl        String?
  audioScript     String?       @db.Text
  status          String        @default("PUBLISHED") 
  assignedBatches String        @default("ALL")
  order           Int           @default(0)
  practiceMode    Boolean       @default(false)
  questions       Question[]
  passages        Passage[]
  sections        Section[]
  writingTasks    WritingTask[]
  attempts        Attempt[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([paperCode, testType])
}

model Passage {
  id            Int     @id @default(autoincrement())
  paperId       Int
  paper         Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  passageNumber Int
  title         String?
  text          String  @db.Text
  groups        QuestionGroup[]
}

model WritingTask {
  id               Int                @id @default(autoincrement())
  paperId          Int
  paper            Paper              @relation(fields: [paperId], references: [id], onDelete: Cascade)
  taskNumber       Int                // 1 or 2
  prompt           String             @db.Text
  chartUrl         String?            // Reverting to chartUrl to avoid data loss, we can rename later
  chartDescription String?            @db.Text
  minWords         Int                @default(150)
  timeMinutes      Int                @default(20)
  tableData        Json?
  submissions      WritingSubmission[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Section {
  id          Int             @id @default(autoincrement())
  paperId     Int
  paper       Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  number      Int             // 1, 2, 3, 4
  description String?         @db.Text
  audioUrl    String?
  groups      QuestionGroup[]
}

model QuestionGroup {
  id           Int        @id @default(autoincrement())
  sectionId    Int?       // Optional: link to section (Listening)
  section      Section?   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  passageId    Int?       // Optional: link to passage (Reading)
  passage      Passage?   @relation(fields: [passageId], references: [id], onDelete: Cascade)
  groupType    String     // FORM_COMPLETION, MAP_LABELING, etc.
  instruction  String?    @db.Text
  imageUrl     String?
  tableData    Json?
  wordLimit    String?
  questions    Question[]
}

model Question {
  id               Int            @id @default(autoincrement())
  paperId          Int
  paper            Paper          @relation(fields: [paperId], references: [id], onDelete: Cascade)
  groupId          Int?
  group            QuestionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  passageNumber    Int?           // For reading (1, 2, 3)
  sectionNumber    Int?           // For listening (1, 2, 3, 4)
  questionNumber   Int
  questionType     String         // TFNG, MC, SA, etc.
  content          String         @db.Text
  options          String?        @db.Text // JSON string
  correctAnswer    String         @db.Text
  explanation      String?        @db.Text
  imageUrl         String?
  audioUrl         String?
  wordLimit        String?
  tableData        Json?
  groupInstruction String?        @db.Text
  answers          Answer[]
}

model Attempt {
  id                 Int                 @id @default(autoincrement())
  studentId          Int
  paperId            Int
  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  paper              Paper               @relation(fields: [paperId], references: [id], onDelete: Cascade)
  startedAt          DateTime            @default(now())
  endedAt            DateTime?
  status             String              @default("IN_PROGRESS")
  answers            Answer[]
  writingSubmission  WritingSubmission?
  speakingSubmission SpeakingSubmission?
  result             Result?
}

model Answer {
  id            Int      @id @default(autoincrement())
  attemptId     Int
  questionId    Int
  studentAnswer String   @db.Text
  isCorrect     Boolean?
  attempt       Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model WritingSubmission {
  id              Int         @id @default(autoincrement())
  attemptId       Int         @unique
  attempt         Attempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  writingTaskId   Int?        // Link to specific task if needed
  writingTask     WritingTask? @relation(fields: [writingTaskId], references: [id])
  task1Response   String?     @db.Text
  task2Response   String?     @db.Text
  task1WordCount  Int?
  task2WordCount  Int?
  task1Band       Float?
  task2Band       Float?
  overallBand     Float?
  aiFeedback      String?     @db.Text
  markingStatus   String      @default("PENDING")
}

model Result {
  id                 Int      @id @default(autoincrement())
  attemptId          Int      @unique
  attempt            Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  rawScore           Float?
  bandEstimate       Float?
  teacherReviewed    Boolean  @default(false)
  overrideBand       Float?
  strengths          String?  @db.Text
  weaknesses          String?  @db.Text
  improvementAdvice  String?  @db.Text
  aiFeedbackJson     String?  @db.Text
  aiFeedback         String?  @db.Text
  finalStudentReport String?  @db.Text
}

model SpeakingSubmission {
  id               Int      @id @default(autoincrement())
  attemptId        Int      @unique
  attempt          Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  part1AudioUrl    String?
  part2AudioUrl    String?
  part3AudioUrl    String?
  part1Transcript  String?  @db.Text
  part2Transcript  String?  @db.Text
  part3Transcript  String?  @db.Text
  part1Band        Float?
  part2Band        Float?
  part3Band        Float?
  overallBand      Float?
  aiFeedback       String?  @db.Text
  markingStatus    String   @default("PENDING")
  createdAt        DateTime @default(now())
}
